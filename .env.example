# Servidor
PORT=3000

# Secreto compartido para proteger /internal/* (llamado por Make.com)
INTERNAL_JOBS_SECRET=

# Anthropic (Claude) - usado por el loop de tool-use de WhatsApp
ANTHROPIC_API_KEY=

# Twilio (WhatsApp Business API)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Número de staff para transferToHuman (formato whatsapp:+58...)
STAFF_WHATSAPP_NUMBER=

# Vapi (voz) - usado para validar firma de webhook si aplica
VAPI_WEBHOOK_SECRET=

# Airtable (sandbox): reservas, mesas y memoria de clientes.
# Personal Access Token con scopes data.records:read/write, schema.bases:read
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# URL pública del backend, una vez desplegado (Railway/Render)
PUBLIC_BASE_URL=

# Enlace de reseña de Google del restaurante (usado en /internal/reviews/run)
GOOGLE_REVIEW_URL=

# Opcional: si se define, /api/* (panel de staff) exige el header x-staff-key
STAFF_API_KEY=
